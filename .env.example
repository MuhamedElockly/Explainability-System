# Copy to .env and fill in values. Do not commit .env.

# Required for Gemini narratives (optional if GEMINI_DISABLE=1)
GEMINI_API_KEY=

# Optional: absolute path to network-flow CSV (see nids_explain/data/dataset.py)
# DATASET_CSV=

# Optional overrides (defaults are in nids_explain/config.py)
# EXPLAIN_SEED=42
# BLIND_SAMPLE_COUNT=8
# GEMINI_DISABLE=0

# Vector RAG (Chroma under rag_chroma/ by default)
# RAG_DISABLE=0
# RAG_EMBEDDING_MODEL=all-MiniLM-L6-v2
# RAG_TOP_K=6
# RAG_FORCE_REBUILD=0
